---
/* Logotipo ESTUDIO AM recreado en código.
   La "A" es un pico (∧) sin travesaño, como en la identidad de la marca.
   Usa currentColor, así que se adapta al color del contexto. */
interface Props {
  class?: string;
}
const { class: cls } = Astro.props;
---

<span class:list={['logo', cls]} aria-label="Estudio AM">
  <span class="logo__word">Estudio</span>
  <span class="logo__mono">
    <svg class="logo__chev" viewBox="0 0 22 16" aria-hidden="true" focusable="false">
      <path d="M1 15.2 L11 1 L21 15.2" fill="none" stroke="currentColor" stroke-width="1.3" />
    </svg>
    <span class="logo__m">M</span>
  </span>
</span>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 1.05rem;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.34em;
    color: inherit;
    white-space: nowrap;
  }
  .logo__word { padding-left: 0.34em; /* compensa el tracking del primer borde */ }
  .logo__mono {
    display: inline-flex;
    align-items: center;
    gap: 0.16em;
  }
  .logo__chev {
    height: 0.82em;
    width: auto;
    display: block;
    transform: translateY(0.02em);
  }
  .logo__m { letter-spacing: 0; }
</style>
