---
import Logo from './Logo.astro';
import { CONTENT, ROUTES, other, type Locale, type PageKey } from '../config/site';

interface Props {
  lang: Locale;
  pageKey: PageKey;
  transparent?: boolean;
}
const { lang, pageKey, transparent = false } = Astro.props;
const t = CONTENT[lang];
const r = ROUTES[lang];

const nav: { label: string; href: string; key: PageKey }[] = [
  { label: t.nav.home, href: r.home, key: 'home' },
  { label: t.nav.portfolio, href: r.portfolio, key: 'portfolio' },
  { label: t.nav.about, href: r.about, key: 'about' },
  { label: t.nav.contact, href: r.contact, key: 'contact' },
];

// URL de la misma página en el otro idioma
const altLang = other(lang);
const altHref = ROUTES[altLang][pageKey];
---

<header class:list={['site-header', { 'is-transparent': transparent }]} data-header>
  <div class="site-header__inner container">
    <a href={r.home} class="brand"><Logo /></a>

    <nav class="nav" aria-label="Navegación principal">
      {nav.map((item) => (
        <a href={item.href} class:list={['nav__link', { 'is-active': item.key === pageKey }]}>{item.label}</a>
      ))}
      <a href={altHref} class="nav__lang" hreflang={altLang} aria-label={`Cambiar idioma a ${altLang.toUpperCase()}`}>{t.langToggle}</a>
    </nav>

    <button class="nav-toggle" aria-label="Abrir menú" aria-expanded="false" data-toggle>
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="mobile-menu" data-mobile-menu hidden>
    <nav class="mobile-menu__nav" aria-label="Navegación móvil">
      {nav.map((item) => <a href={item.href} class="mobile-menu__link">{item.label}</a>)}
      <a href={altHref} class="mobile-menu__lang" hreflang={altLang}>{t.langToggle}</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 50;
    background: var(--cream);
    border-bottom: 1px solid var(--line);
    transition: background-color 0.4s ease, border-color 0.4s ease;
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 78px;
  }
  .brand { color: var(--ink); }
  .nav { display: flex; align-items: center; gap: clamp(1.4rem, 2.6vw, 2.8rem); }
  .nav__link {
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink);
    padding-block: 0.4rem;
    position: relative;
  }
  .nav__link::after {
    content: '';
    position: absolute; left: 0; bottom: 0;
    width: 0; height: 1px; background: var(--maroon);
    transition: width 0.3s ease;
  }
  .nav__link:hover::after, .nav__link.is-active::after { width: 100%; }

  .nav__lang {
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    font-weight: 400;
    color: var(--maroon);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.4em 0.8em;
  }
  .nav__lang:hover { background: var(--olive); color: var(--cream); border-color: var(--olive); }

  .site-header.is-transparent { background: transparent; border-color: transparent; }
  .site-header.is-transparent .brand,
  .site-header.is-transparent .nav__link { color: var(--cream); }
  .site-header.is-transparent .nav__lang { color: var(--cream); border-color: rgba(250,246,238,0.5); }
  .site-header.is-transparent .nav-toggle span { background: var(--cream); }

  .site-header.is-transparent.is-scrolled { background: var(--cream); border-color: var(--line); }
  .site-header.is-transparent.is-scrolled .brand,
  .site-header.is-transparent.is-scrolled .nav__link { color: var(--ink); }
  .site-header.is-transparent.is-scrolled .nav__lang { color: var(--maroon); border-color: var(--line); }
  .site-header.is-transparent.is-scrolled .nav-toggle span { background: var(--ink); }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    width: 30px;
    background: none; border: 0; cursor: pointer; padding: 4px;
  }
  .nav-toggle span { height: 1.5px; width: 100%; background: var(--ink); transition: transform 0.3s ease, opacity 0.3s ease; }
  .nav-toggle[aria-expanded='true'] span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .nav-toggle[aria-expanded='true'] span:nth-child(2) { opacity: 0; }
  .nav-toggle[aria-expanded='true'] span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  .mobile-menu {
    position: fixed;
    inset: 78px 0 0 0;
    background: var(--olive);
    z-index: 40;
    display: grid; place-items: center;
  }
  .mobile-menu[hidden] { display: none; }
  .mobile-menu__nav { display: flex; flex-direction: column; align-items: center; gap: 1.6rem; }
  .mobile-menu__link { font-family: var(--font-display); font-size: 2.1rem; color: var(--cream); }
  .mobile-menu__lang {
    margin-top: 0.5rem;
    font-size: 0.8rem; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--beige);
    border: 1px solid rgba(250,246,238,0.5); border-radius: 999px; padding: 0.5em 1.1em;
  }

  @media (max-width: 860px) {
    .nav { display: none; }
    .nav-toggle { display: flex; }
    .site-header.is-transparent { background: var(--cream); border-color: var(--line); }
    .site-header.is-transparent .brand { color: var(--ink); }
    .site-header.is-transparent .nav-toggle span { background: var(--ink); }
  }
</style>

<script>
  const header = document.querySelector('[data-header]');
  const toggle = document.querySelector('[data-toggle]');
  const menu = document.querySelector('[data-mobile-menu]') as HTMLElement | null;

  if (header?.classList.contains('is-transparent')) {
    const onScroll = () => header.classList.toggle('is-scrolled', window.scrollY > 40);
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }

  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!open));
    if (menu) menu.hidden = open;
    document.body.style.overflow = open ? '' : 'hidden';
  });
</script>
