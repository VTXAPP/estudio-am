---
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import ContactCTA from '../ContactCTA.astro';
import { CONTENT, ROUTES, HERO, PHOTOS, type Locale } from '../../config/site';

const { lang } = Astro.props as { lang: Locale };
const t = CONTENT[lang];
const r = ROUTES[lang];
const featured = PHOTOS.filter((p) => p.feat);
---

<Base lang={lang} pageKey="home" transparentHeader={true}>
  <!-- HERO -->
  <section class="hero">
    <Image src={HERO} alt={t.hero.title} class="hero__img" widths={[768, 1100, 1500]} sizes="100vw" loading="eager" fetchpriority="high" />
    <div class="hero__overlay"></div>
    <div class="hero__content container">
      <p class="eyebrow hero__eyebrow">{t.hero.eyebrow}</p>
      <h1 class="display-xl hero__title">{t.hero.title}</h1>
      <a href={r.portfolio} class="btn btn--light hero__btn">{t.hero.cta}</a>
    </div>
    <div class="hero__scroll" aria-hidden="true">{t.scroll}</div>
  </section>

  <!-- INTRO (frase) -->
  <section class="section intro">
    <div class="container intro__inner reveal">
      <p class="display-md intro__text">{t.intro}</p>
    </div>
  </section>

  <!-- SELECCIÓN -->
  <section class="section featured">
    <div class="container">
      <div class="section-head reveal">
        <p class="eyebrow">{t.featured.eyebrow}</p>
        <h2 class="display-lg">{t.featured.title}</h2>
      </div>
      <div class="featured__grid">
        {featured.map((img) => (
          <figure class="featured__item reveal">
            <Image src={img.src} alt={img.alt[lang]} widths={[400, 700, 1000]} sizes="(max-width: 520px) 100vw, (max-width: 820px) 50vw, 33vw" />
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- NUESTRA MIRADA (texto de marca) -->
  <section class="section approach">
    <div class="container approach__inner reveal">
      <div class="approach__head">
        <p class="eyebrow">{t.approach.eyebrow}</p>
        <h2 class="display-lg">{t.approach.title}</h2>
      </div>
      <div class="approach__cols">
        <p>{t.approach.col1}</p>
        <p>{t.approach.col2}</p>
      </div>
    </div>
  </section>

  <!-- SERVICIOS -->
  <section class="section services">
    <div class="container">
      <div class="section-head reveal">
        <p class="eyebrow">{t.services.eyebrow}</p>
        <h2 class="display-lg">{t.services.title}</h2>
      </div>
      <div class="services__grid">
        {t.services.items.map((s) => (
          <article class="svc-card reveal">
            <h3 class="display-md">{s.title}</h3>
            <p class="svc-card__text">{s.text}</p>
            <a href={r.contact} class="svc-card__link">{t.services.cta} →</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- FRASE -->
  <section class="quote-band">
    <div class="container reveal">
      <blockquote class="quote-band__q">“{t.quote}”</blockquote>
    </div>
  </section>

  <ContactCTA lang={lang} />
</Base>

<style>
  .hero { position: relative; height: 100svh; min-height: 560px; display: grid; }
  .hero__img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: 32% 62%; }
  .hero__overlay { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(40,34,18,0.34) 0%, rgba(40,34,18,0.12) 42%, rgba(40,34,18,0.58) 100%); }
  .hero__content { position: relative; align-self: center; text-align: center; color: var(--cream); display: flex; flex-direction: column; align-items: center; gap: 1.5rem; }
  .hero__eyebrow { color: var(--beige); }
  .hero__title { color: var(--cream); max-width: 16ch; }
  .hero__btn { margin-top: 0.5rem; }
  .hero__scroll { position: absolute; bottom: 1.75rem; left: 50%; transform: translateX(-50%); color: rgba(250,246,238,0.85); font-size: 0.68rem; letter-spacing: 0.3em; text-transform: uppercase; writing-mode: vertical-rl; }

  .intro { background: var(--cream); text-align: center; }
  .intro__inner { max-width: 880px; }
  .intro__text { color: var(--ink); font-weight: 400; font-style: italic; }

  .featured { background: var(--beige-soft); }
  .featured__grid { columns: 3; column-gap: clamp(0.75rem, 1.5vw, 1.5rem); }
  .featured__item { break-inside: avoid; margin-bottom: clamp(0.75rem, 1.5vw, 1.5rem); overflow: hidden; }
  .featured__item img { width: 100%; transition: transform 0.7s ease; }
  .featured__item:hover img { transform: scale(1.04); }

  .approach { background: var(--cream); }
  .approach__head { margin-bottom: clamp(1.5rem, 3vw, 2.5rem); }
  .approach__head .eyebrow { display: block; margin-bottom: 0.6rem; }
  .approach__cols { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(1.5rem, 4vw, 4rem); }
  .approach__cols p { color: var(--ink-soft); max-width: 46ch; }

  .services { background: var(--beige-soft); }
  .services__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(1.5rem, 3vw, 2.75rem); }
  .svc-card { border-top: 1px solid var(--line); padding-top: 1.5rem; }
  .svc-card__text { color: var(--ink-soft); margin-top: 0.6rem; max-width: 40ch; }
  .svc-card__link { display: inline-block; margin-top: 1rem; font-size: 0.78rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--maroon); }

  .quote-band { background: var(--sand); padding-block: clamp(3.5rem, 7vw, 6rem); text-align: center; }
  .quote-band__q { font-family: var(--font-display); font-style: italic; font-size: clamp(1.5rem, 3vw, 2.4rem); line-height: 1.3; color: var(--olive); max-width: 28ch; margin: 0 auto; }

  @media (max-width: 820px) {
    .featured__grid { columns: 2; }
    .approach__cols { grid-template-columns: 1fr; }
    .services__grid { grid-template-columns: 1fr; max-width: 460px; margin-inline: auto; }
  }
  @media (max-width: 520px) { .featured__grid { columns: 1; } }
</style>
