---
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import ContactCTA from '../ContactCTA.astro';
import { CONTENT, PHOTOS, type Locale, type Category } from '../../config/site';

const { lang } = Astro.props as { lang: Locale };
const t = CONTENT[lang];

const filters: { key: 'all' | Category; label: string }[] = [
  { key: 'all', label: t.portfolio.filters.all },
  { key: 'bodas', label: t.portfolio.filters.bodas },
  { key: 'eventos', label: t.portfolio.filters.eventos },
  { key: 'retratos', label: t.portfolio.filters.retratos },
];
---

<Base lang={lang} pageKey="portfolio" title={t.nav.portfolio}>
  <section class="p-head section">
    <div class="container reveal">
      <p class="eyebrow">{t.portfolio.eyebrow}</p>
      <h1 class="display-lg">{t.portfolio.title}</h1>
      <p class="lead p-head__lead">{t.portfolio.lead}</p>

      <div class="filters" role="tablist" aria-label={t.portfolio.eyebrow}>
        {filters.map((f, i) => (
          <button class:list={['filter', { 'is-active': i === 0 }]} data-filter={f.key} type="button">{f.label}</button>
        ))}
      </div>
    </div>
  </section>

  <section class="p-grid-wrap">
    <div class="container">
      <div class="p-grid" data-grid>
        {PHOTOS.map((img, i) => (
          <figure class="p-item reveal" data-cat={img.cat} data-index={i}>
            <Image src={img.src} alt={img.alt[lang]} widths={[500, 900, 1400]} sizes="(max-width: 520px) 100vw, (max-width: 820px) 50vw, 33vw" loading={i < 3 ? 'eager' : 'lazy'} />
          </figure>
        ))}
      </div>
    </div>
  </section>

  <ContactCTA lang={lang} />

  <div class="lightbox" data-lightbox hidden>
    <button class="lightbox__close" data-lb-close aria-label="Cerrar / Close">×</button>
    <button class="lightbox__nav lightbox__nav--prev" data-lb-prev aria-label="Anterior / Previous">‹</button>
    <img class="lightbox__img" data-lb-img src="" alt="" />
    <button class="lightbox__nav lightbox__nav--next" data-lb-next aria-label="Siguiente / Next">›</button>
  </div>
</Base>

<style>
  .p-head { text-align: center; padding-top: calc(78px + clamp(3rem, 6vw, 6rem)); background: var(--beige-soft); }
  .p-head__lead { max-width: 58ch; margin: 1.25rem auto 0; }

  .filters { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.6rem; margin-top: 2.25rem; }
  .filter {
    font-family: var(--font-body); font-size: 0.74rem; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--ink-soft); background: none; border: 1px solid var(--line); border-radius: 999px;
    padding: 0.6em 1.3em; cursor: pointer; transition: all 0.3s ease;
  }
  .filter:hover { color: var(--ink); border-color: var(--olive-soft); }
  .filter.is-active { background: var(--olive); color: var(--cream); border-color: var(--olive); }

  .p-grid-wrap { padding-block: clamp(3rem, 6vw, 6rem); }
  .p-grid { columns: 3; column-gap: clamp(0.75rem, 1.5vw, 1.5rem); }
  .p-item { break-inside: avoid; margin-bottom: clamp(0.75rem, 1.5vw, 1.5rem); overflow: hidden; cursor: zoom-in; }
  .p-item.is-hidden { display: none; }
  .p-item img { width: 100%; transition: transform 0.7s ease; }
  .p-item:hover img { transform: scale(1.04); }

  @media (max-width: 820px) { .p-grid { columns: 2; } }
  @media (max-width: 520px) { .p-grid { columns: 1; } }

  .lightbox { position: fixed; inset: 0; z-index: 100; background: rgba(40, 34, 18, 0.95); display: grid; place-items: center; padding: clamp(1rem, 4vw, 3rem); }
  .lightbox[hidden] { display: none; }
  .lightbox__img { max-width: min(92vw, 1100px); max-height: 86vh; object-fit: contain; box-shadow: 0 30px 80px rgba(0,0,0,0.5); }
  .lightbox__close, .lightbox__nav { position: absolute; background: none; border: 0; color: var(--cream); cursor: pointer; line-height: 1; transition: opacity 0.2s ease; }
  .lightbox__close { top: clamp(1rem,3vw,2rem); right: clamp(1rem,3vw,2rem); font-size: 2.5rem; }
  .lightbox__nav { top: 50%; transform: translateY(-50%); font-size: 3.5rem; padding: 0 1rem; }
  .lightbox__nav--prev { left: clamp(0.25rem,2vw,1.5rem); }
  .lightbox__nav--next { right: clamp(0.25rem,2vw,1.5rem); }
  .lightbox__close:hover, .lightbox__nav:hover { opacity: 0.6; }
  @media (max-width: 520px) { .lightbox__nav { font-size: 2.5rem; } }
</style>

<script>
  // --- Filtros por categoría ---
  const buttons = Array.from(document.querySelectorAll('[data-filter]')) as HTMLButtonElement[];
  const allItems = Array.from(document.querySelectorAll('.p-item')) as HTMLElement[];

  function applyFilter(cat: string) {
    allItems.forEach((it) => {
      const show = cat === 'all' || it.dataset.cat === cat;
      it.classList.toggle('is-hidden', !show);
    });
  }
  buttons.forEach((b) => b.addEventListener('click', () => {
    buttons.forEach((x) => x.classList.remove('is-active'));
    b.classList.add('is-active');
    applyFilter(b.dataset.filter || 'all');
  }));

  // --- Lightbox (solo sobre las imágenes visibles) ---
  const lb = document.querySelector('[data-lightbox]') as HTMLElement | null;
  const lbImg = document.querySelector('[data-lb-img]') as HTMLImageElement | null;
  let visible: HTMLImageElement[] = [];
  let current = 0;

  function refreshVisible() {
    visible = allItems.filter((it) => !it.classList.contains('is-hidden'))
      .map((it) => it.querySelector('img') as HTMLImageElement);
  }
  function show(i: number) {
    if (!lb || !lbImg) return;
    refreshVisible();
    if (!visible.length) return;
    current = (i + visible.length) % visible.length;
    const img = visible[current];
    lbImg.src = img.currentSrc || img.src;
    lbImg.alt = img.alt;
    lb.hidden = false;
    document.body.style.overflow = 'hidden';
  }
  function close() { if (lb) { lb.hidden = true; document.body.style.overflow = ''; } }

  allItems.forEach((it) => it.addEventListener('click', () => {
    refreshVisible();
    const img = it.querySelector('img') as HTMLImageElement;
    show(visible.indexOf(img));
  }));
  document.querySelector('[data-lb-close]')?.addEventListener('click', close);
  document.querySelector('[data-lb-next]')?.addEventListener('click', () => show(current + 1));
  document.querySelector('[data-lb-prev]')?.addEventListener('click', () => show(current - 1));
  lb?.addEventListener('click', (e) => { if (e.target === lb) close(); });
  document.addEventListener('keydown', (e) => {
    if (lb?.hidden) return;
    if (e.key === 'Escape') close();
    if (e.key === 'ArrowRight') show(current + 1);
    if (e.key === 'ArrowLeft') show(current - 1);
  });
</script>
