---
import Base from '../../layouts/Base.astro';
import { CONTENT, SITE, links, type Locale } from '../../config/site';

const { lang } = Astro.props as { lang: Locale };
const t = CONTENT[lang];
const l = links(lang);
const f = t.contact.form;
---

<Base lang={lang} pageKey="contact" title={t.nav.contact}>
  <section class="contact section">
    <div class="container contact__grid">
      <div class="contact__intro reveal">
        <p class="eyebrow">{t.contact.eyebrow}</p>
        <h1 class="display-lg contact__title">{t.contact.title}</h1>
        <p class="contact__lead">{t.contact.lead}</p>

        <ul class="channels">
          <li>
            <a href={l.whatsapp} target="_blank" rel="noopener" class="channel">
              <span class="channel__label">{t.contact.waLabel}</span>
              <span class="channel__value">{t.contact.waValue}</span>
            </a>
          </li>
          <li>
            <a href={l.email} class="channel">
              <span class="channel__label">{t.contact.emailLabel}</span>
              <span class="channel__value">{SITE.contact.email}</span>
            </a>
          </li>
          <li>
            <a href={l.instagram} target="_blank" rel="noopener" class="channel">
              <span class="channel__label">{t.contact.igLabel}</span>
              <span class="channel__value">{SITE.contact.instagram.handle}</span>
            </a>
          </li>
        </ul>
      </div>

      <div class="contact__form-wrap reveal">
        <form class="form" data-contact-form>
          <label class="field"><span>{f.name}</span><input type="text" name="nombre" required placeholder={f.namePh} /></label>
          <label class="field">
            <span>{f.type}</span>
            <select name="tipo">{f.types.map((ty) => <option>{ty}</option>)}</select>
          </label>
          <label class="field"><span>{f.date}</span><input type="text" name="fecha" placeholder={f.datePh} /></label>
          <label class="field"><span>{f.message}</span><textarea name="mensaje" rows="4" placeholder={f.messagePh}></textarea></label>
          <div class="form__actions">
            <button type="submit" class="btn btn--solid" data-send="whatsapp">{f.sendWa}</button>
            <button type="submit" class="btn btn--outline" data-send="email">{f.sendEmail}</button>
          </div>
          <p class="form__note">{f.note}</p>
        </form>
      </div>
    </div>
  </section>
</Base>

<style>
  .contact { padding-top: calc(78px + clamp(3rem, 6vw, 6rem)); }
  .contact__grid { display: grid; grid-template-columns: 1fr 1.05fr; gap: clamp(2.5rem, 6vw, 6rem); }
  .contact__title { margin: 0.5rem 0 1.25rem; }
  .contact__lead { color: var(--ink-soft); max-width: 46ch; }

  .channels { list-style: none; padding: 0; margin: 2.5rem 0 0; }
  .channels li { border-top: 1px solid var(--line); }
  .channels li:last-child { border-bottom: 1px solid var(--line); }
  .channel { display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; padding: 1.25rem 0; transition: padding-left 0.3s ease; }
  .channel:hover { padding-left: 0.6rem; }
  .channel__label { font-size: 0.78rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink); }
  .channel__value { color: var(--maroon); }

  .contact__form-wrap { background: var(--beige-soft); padding: clamp(1.75rem, 4vw, 3rem); }
  .field { display: block; margin-bottom: 1.25rem; }
  .field span { display: block; font-size: 0.72rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink-soft); margin-bottom: 0.5rem; }
  .field input, .field select, .field textarea {
    width: 100%; font-family: var(--font-body); font-size: 1rem; color: var(--ink);
    background: var(--cream); border: 1px solid var(--line); border-radius: 4px; padding: 0.85rem 1rem;
  }
  .field input:focus, .field select:focus, .field textarea:focus { outline: none; border-color: var(--olive); }
  .field textarea { resize: vertical; }
  .form__actions { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 0.5rem; }
  .form__note { font-size: 0.78rem; color: var(--ink-soft); margin-top: 1.25rem; }

  @media (max-width: 760px) { .contact__grid { grid-template-columns: 1fr; } }
</style>

<script is:inline define:vars={{ wa: SITE.contact.whatsapp, mail: SITE.contact.email, L: { greeting: f.greeting, type: f.fType, date: f.fDate, subject: f.subject } }}>
  const form = document.querySelector('[data-contact-form]');
  let channel = 'whatsapp';
  form?.querySelectorAll('[data-send]').forEach((btn) => {
    btn.addEventListener('click', () => { channel = btn.getAttribute('data-send'); });
  });
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const fd = new FormData(form);
    const nombre = fd.get('nombre') || '';
    const tipo = fd.get('tipo') || '';
    const fecha = fd.get('fecha') || '';
    const mensaje = fd.get('mensaje') || '';
    const cuerpo = `${L.greeting} ${nombre}.\n${L.type}: ${tipo}\n${L.date}: ${fecha}\n\n${mensaje}`;
    if (channel === 'whatsapp') {
      window.open(`https://wa.me/${wa}?text=${encodeURIComponent(cuerpo)}`, '_blank');
    } else {
      window.location.href = `mailto:${mail}?subject=${encodeURIComponent(L.subject + ' ' + tipo + ' — ' + nombre)}&body=${encodeURIComponent(cuerpo)}`;
    }
  });
</script>
